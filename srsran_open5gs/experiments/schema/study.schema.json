{
  "$id": "evaluation-study.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "amf_safety": {
      "type": "object"
    },
    "baseline_policy": {
      "type": "object"
    },
    "conditions": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "parameter_files": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array"
    },
    "parameters": {
      "type": "object"
    },
    "pilot": {
      "type": "boolean"
    },
    "result_root": {
      "minLength": 1,
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "study_id": {
      "minLength": 1,
      "type": "string"
    },
    "trials_per_condition": {
      "minimum": 1,
      "type": "integer"
    }
  },
  "required": [
    "schema_version",
    "study_id",
    "trials_per_condition",
    "conditions",
    "baseline_policy",
    "amf_safety"
  ],
  "title": "Evaluation experiment study",
  "type": "object"
}
