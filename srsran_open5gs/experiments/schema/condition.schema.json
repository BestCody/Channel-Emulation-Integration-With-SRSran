{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evaluation-condition.schema.json",
  "title": "Evaluation experiment condition",
  "type": "object",
  "required": [
    "schema_version",
    "condition_id",
    "label",
    "scene",
    "measurement_profile",
    "throughput"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "condition_id": {"type": "string", "minLength": 1},
    "label": {"type": "string", "minLength": 1},
    "scene": {"type": "string", "minLength": 1},
    "propagation": {"type": "object"},
    "mobility": {"enum": ["static", "moving"]},
    "trajectory": {"type": "string", "minLength": 1},
    "noise": {"type": "object"},
    "measurement_profile": {"type": "string", "minLength": 1},
    "throughput": {"type": "object"}
  },
  "additionalProperties": true
}
